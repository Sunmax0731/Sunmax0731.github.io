{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workspace",
  "type": "object",
  "required": [
    "id",
    "name",
    "currentStageId",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "currentStageId": {
      "type": "string",
      "pattern": "^stage-\\d{2}$"
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
